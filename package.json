{
  "name": "rsbuild-plugin-devtools-json",
  "version": "1.0.1",
  "repository": "https://github.com/rstackjs/rsbuild-plugin-devtools-json",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-devtools-json#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-devtools-json/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "bump": "npx bumpp",
    "dev": "rslib -w",
    "format": "prettier -w .",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "devDependencies": {
    "@rslib/core": "0.23.1",
    "@rslint/core": "^0.6.4",
    "@types/node": "24.13.2",
    "prettier": "^3.9.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.2",
    "uuid": "^14.0.1"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.4.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
